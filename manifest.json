{
  "manifest_version": 3,
  "name": "Article Checker Beta",
  "version": "0.0.2",
  "description": "選取網頁內容，基於Gemini AI給予優化建議。",
  "author": "cjzopen",
  "default_locale": "zh_TW",
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Article Checker"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ]
}